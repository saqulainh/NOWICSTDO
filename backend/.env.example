# ADMIN_USER (required): admin login username.
# Format: 3-64 chars, letters/numbers/._- only. Example: admin
ADMIN_USER=admin

# ADMIN_PASS (required): admin login password.
# Use a strong password (at least 12 chars, mixed case, numbers, symbols). Never commit real values.
ADMIN_PASS=change-this-strong-password

# ADMIN_SESSION_SECRET (required): cryptographically secure secret used to sign session tokens.
# Generate 32-64 random bytes (hex/base64), keep it unpredictable and private.
# Examples: openssl rand -hex 64  OR  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Do NOT use short, guessable, or reused secrets.
ADMIN_SESSION_SECRET=replace-with-random-64-byte-secret

# PORT (optional): server bind port. Use a fixed internal port in production (example: 8787).
PORT=8787